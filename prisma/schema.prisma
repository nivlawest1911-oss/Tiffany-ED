generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

model Tier {
  id        String @id @default(cuid())
  name      String @unique
  stripeUrl String
  users     User[]

  @@map("tiers")
}

model User {
  id                   String                @id @default(cuid())
  clerkId              String                @unique @map("clerk_id")
  email                String                @unique
  name                 String?
  role                 UserRole              @default(TEACHER) @map("role")
  district             String?
  school               String?
  schoolSite           String?               @map("school_site")
  position             String?
  bio                  String?
  organizationId       String?               @map("organization_id")
  schoolId             String?               @map("school_id")
  stripeCustomerId     String?               @unique @map("stripe_customer_id")
  stripeSubscriptionId String?               @unique @map("stripe_subscription_id")
  subscriptionTier     String                @default("free") @map("subscription_tier")
  subscriptionStatus   String                @default("inactive") @map("subscription_status")
  usageTokens          Int                   @default(10) @map("usage_tokens")
  xpPoints             Int                   @default(0) @map("xp_points")
  trialStartedAt       DateTime              @default(now()) @map("trial_started_at")
  trialEndsAt          DateTime?             @map("trial_ends_at")
  isTrialConverted     Boolean               @default(false) @map("is_trial_converted")
  isActive             Boolean               @default(true) @map("is_active")
  tierId               String?               @map("tier_id")
  avatarUrl            String?               @map("avatar_url")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  lastLogin            DateTime?             @map("last_login")
  analyticsHistory     AnalyticsData[]
  avatarSessions       AvatarSession[]
  conversationHistory  ConversationMessage[]
  evidenceFolders      EvidenceFolder[]
  generatedContent     GeneratedContent[]
  generations          Generation[]
  observations         Observation[]
  savedItems           SavedContent[]
  managedSchools       School[]              @relation("SchoolAdmin")
  subscriptions        Subscription[]
  feedbackSent         SystemFeedback[]
  usageHistory         UsageTracker[]
  organization         Organization?         @relation(fields: [organizationId], references: [id])
  schoolRelation       School?               @relation(fields: [schoolId], references: [id])
  tier                 Tier?                 @relation(fields: [tierId], references: [id])
  vaultDocuments       VaultDocument[]
  strategicVault       StrategicVault[]
  legacyLedger         LegacyLedger[]

  @@index([email])
  @@index([clerkId])
  @@index([district, school])
  @@index([organizationId])
  @@index([schoolId])
  @@map("users")
}

model School {
  id               String          @id @default(cuid())
  name             String
  districtName     String?         @map("district_name")
  state            String?
  zipCode          String?         @map("zip_code")
  adminId          String?         @map("admin_id")
  stripeCustomerId String?         @unique @map("stripe_customer_id")
  subscriptionTier String          @default("free") @map("subscription_tier")
  maxUsers         Int             @default(5) @map("max_users")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  analyticsHistory AnalyticsData[]
  admin            User?           @relation("SchoolAdmin", fields: [adminId], references: [id])
  subscriptions    Subscription[]
  users            User[]

  @@index([adminId])
  @@map("schools")
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  tier             String   @default("SCHOOL_SITE")
  trialStartedAt   DateTime @default(now()) @map("trial_started_at")
  trialStartsAt    DateTime @default(now()) @map("trial_starts_at")
  trialEndsAt      DateTime @map("trial_ends_at")
  isTrialConverted Boolean  @default(false) @map("is_trial_converted")
  usageTokens      Int      @default(0) @map("usage_tokens")
  address          String?
  contactEmail     String?  @map("contact_email")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  users            User[]

  @@map("organizations")
}

model Avatar {
  id             String          @id @default(cuid())
  name           String
  description    String?
  systemPrompt   String          @map("system_prompt")
  voiceId        String          @map("voice_id")
  avatarImageUrl String?         @map("avatar_image_url")
  category       String
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  sessions       AvatarSession[]

  @@map("avatars")
}

model AvatarSession {
  id                String                @id @default(cuid())
  userId            String
  avatarId          String?               @map("avatar_id")
  avatarName        String
  avatarRole        String
  engine            String                @default("duix")
  startedAt         DateTime              @default(now())
  endedAt           DateTime?
  duration          Int?
  latencyAvg        Float?
  conversationLog   Json
  userSentiment     String?
  gcpSessionId      String?               @unique
  vertexAiModel     String                @default("gemini-1.5-pro")
  cloudRunEndpoint  String?
  thoughtSignatures Json?
  avatar            Avatar?               @relation(fields: [avatarId], references: [id])
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          ConversationMessage[]
  observations      Observation[]

  @@index([userId, startedAt])
  @@index([gcpSessionId])
  @@map("avatar_sessions")
}

model ConversationMessage {
  id        String         @id @default(cuid())
  sessionId String?        @map("session_id")
  userId    String         @map("user_id")
  role      String
  content   String
  feedback  Int?
  metadata  Json?
  createdAt DateTime       @default(now()) @map("created_at")
  session   AvatarSession? @relation(fields: [sessionId], references: [id])
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@map("conversation_messages")
}

model GeneratedContent {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  type          String
  title         String
  description   String?
  prompt        String
  content       Json?
  legacyContent String?        @map("legacy_content")
  subject       String?
  gradeLevel    String?        @map("grade_level")
  mediaUrls     String[]       @map("media_urls")
  aiModel       String?        @map("ai_model")
  tokensUsed    Int?           @map("tokens_used")
  isPublic      Boolean        @default(false) @map("is_public")
  tags          String[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedBy       SavedContent[]

  @@index([userId])
  @@index([type])
  @@map("generated_content_hub")
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String?  @map("user_id")
  schoolId             String?  @map("school_id")
  stripeSubscriptionId String   @unique @map("stripe_subscription_id")
  stripePriceId        String   @map("stripe_price_id")
  status               String
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  school               School?  @relation(fields: [schoolId], references: [id])
  user                 User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([schoolId])
  @@map("subscriptions")
}

model UsageTracker {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  month              DateTime @db.Date
  conversationsCount Int      @default(0) @map("conversations_count")
  messagesCount      Int      @default(0) @map("messages_count")
  contentGenerated   Int      @default(0) @map("content_generated")
  imagesGenerated    Int      @default(0) @map("images_generated")
  videosGenerated    Int      @default(0) @map("videos_generated")
  voiceMinutes       Int      @default(0) @map("voice_minutes")
  tokensUsed         Int      @default(0) @map("tokens_used")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
  @@map("usage_tracking")
}

model AnalyticsData {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  schoolId           String?  @map("school_id")
  date               DateTime @db.Date
  timeSavedHours     Decimal  @default(0) @map("time_saved_hours")
  lessonsCreated     Int      @default(0) @map("lessons_created")
  studentsEngaged    Int      @default(0) @map("students_engaged")
  assessmentsCreated Int      @default(0) @map("assessments_created")
  createdAt          DateTime @default(now()) @map("created_at")
  school             School?  @relation(fields: [schoolId], references: [id])
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schoolId])
  @@index([date])
  @@map("analytics_insights")
}

model SavedContent {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  contentId  String           @map("content_id")
  folderName String?          @map("folder_name")
  createdAt  DateTime         @default(now()) @map("created_at")
  content    GeneratedContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@map("saved_items")
}

model SystemFeedback {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  type        String
  rating      Int?
  message     String?
  contextData Json?    @map("context_data")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@map("system_feedback")
}

model EvidenceFolder {
  id              String        @id @default(cuid())
  userId          String
  studentId       String
  gradeLevel      String?
  specialEdStatus String?
  title           String
  category        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  aiSummary       String?
  riskLevel       String?
  complianceScore Float?
  documents       Document[]
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  observations    Observation[]

  @@index([userId, studentId])
  @@index([category, riskLevel])
  @@map("evidence_folders")
}

model Observation {
  id               String          @id @default(cuid())
  userId           String
  evidenceFolderId String?
  avatarSessionId  String?
  observationType  String
  observationDate  DateTime        @default(now())
  duration         Int?
  description      String
  context          String?
  interventions    String?
  aiAnalysis       String?
  suggestedActions Json?
  legalCompliance  Boolean         @default(false)
  hasAudio         Boolean         @default(false)
  hasVideo         Boolean         @default(false)
  hasImages        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  avatarSession    AvatarSession?  @relation(fields: [avatarSessionId], references: [id])
  evidenceFolder   EvidenceFolder? @relation(fields: [evidenceFolderId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, observationDate])
  @@index([evidenceFolderId])
  @@index([observationType])
  @@map("observations")
}

model Document {
  id               String         @id @default(cuid())
  evidenceFolderId String
  fileName         String
  fileType         String
  fileSize         Int
  gcpBucketPath    String
  gcpSignedUrl     String?
  urlExpiresAt     DateTime?
  encrypted        Boolean        @default(true)
  accessLevel      String         @default("private")
  uploadedAt       DateTime       @default(now())
  evidenceFolder   EvidenceFolder @relation(fields: [evidenceFolderId], references: [id], onDelete: Cascade)

  @@index([evidenceFolderId])
  @@index([fileType])
  @@map("documents")
}

model Generation {
  id                String   @id @default(cuid())
  userId            String
  generatorId       String
  prompt            String
  content           String
  professorVideoUrl String?
  avatarEngine      String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([generatorId])
  @@map("generations")
}

model AnalyticsEvent {
  id            String   @id @default(cuid())
  userId        String?
  eventType     String
  eventCategory String
  eventAction   String
  eventLabel    String?
  latency       Float?
  tokensUsed    Int?
  gcpCost       Float?
  metadata      Json?
  userAgent     String?
  ipAddress     String?
  timestamp     DateTime @default(now())

  @@index([eventType, timestamp])
  @@index([userId, timestamp])
  @@map("analytics_events")
}

model SemanticCache {
  id        String   @id @default(cuid())
  query     String
  response  String
  hitCount  Int      @default(0) @map("hit_count")
  lastHitAt DateTime @default(now()) @map("last_hit_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("semantic_caches")
}

model GraphNode {
  id         String      @id @default(cuid())
  label      String
  name       String
  properties Json?
  createdAt  DateTime    @default(now()) @map("created_at")
  outbound   GraphEdge[] @relation("OutboundEdges")
  inbound    GraphEdge[] @relation("InboundEdges")

  @@index([label])
  @@map("graph_nodes")
}

model GraphEdge {
  id         String    @id @default(cuid())
  type       String
  properties Json?
  sourceId   String
  targetId   String
  weight     Float     @default(1.0)
  createdAt  DateTime  @default(now()) @map("created_at")
  source     GraphNode @relation("OutboundEdges", fields: [sourceId], references: [id], onDelete: Cascade)
  target     GraphNode @relation("InboundEdges", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([targetId])
  @@index([type])
  @@map("graph_edges")
}

model VaultDocument {
  id            String       @id @default(cuid())
  userId        String
  fileName      String
  fileSize      Int
  fileType      String
  storagePath   String
  isEncrypted   Boolean      @default(true)
  securityLevel String       @default("confidential")
  tags          String[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  audits        VaultAudit[]
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ocrContent    VaultOCR?

  @@index([userId])
  @@map("vault_documents")
}

model VaultAudit {
  id         String        @id @default(cuid())
  documentId String
  userId     String
  action     String
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime      @default(now())
  document   VaultDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("vault_audits")
}

model VaultOCR {
  id            String        @id @default(cuid())
  documentId    String        @unique
  extractedText String
  confidence    Float?
  processedAt   DateTime      @default(now())
  document      VaultDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("vault_ocr")
}

model StrategicVault {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  fileName  String   @map("file_name")
  content   String?
  metadata  Json     @default("{}")
  tags      String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("strategic_vault")
}

model LegacyLedger {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  title           String
  directive       String
  logic           String
  swarmContext    Json     @map("swarm_context")
  outcome         String?
  learnings       String?
  isImmutable     Boolean  @default(true) @map("is_immutable")
  tags            String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("legacy_ledger")
}

enum UserRole {
  TEACHER
  ADMIN
  COUNSELOR
  STUDENT
  SUPERINTENDENT
  EXECUTIVE
}
