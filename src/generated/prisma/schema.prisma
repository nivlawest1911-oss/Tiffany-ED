generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model analytics_events {
  id            String   @id
  userId        String?
  eventType     String
  eventCategory String
  eventAction   String
  eventLabel    String?
  latency       Float?
  tokensUsed    Int?
  gcpCost       Float?
  metadata      Json?
  userAgent     String?
  ipAddress     String?
  timestamp     DateTime @default(now())

  @@index([eventType, timestamp])
  @@index([userId, timestamp])
}

model analytics_insights {
  id                  String   @id
  user_id             String
  school_id           String?
  date                DateTime @db.Date
  time_saved_hours    Decimal  @default(0)
  lessons_created     Int      @default(0)
  students_engaged    Int      @default(0)
  assessments_created Int      @default(0)
  created_at          DateTime @default(now())
  schools             schools? @relation(fields: [school_id], references: [id])
  users               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([school_id])
  @@index([user_id])
}

model avatar_sessions {
  id                    String                  @id
  userId                String
  avatar_id             String?
  avatarName            String
  avatarRole            String
  engine                String                  @default("duix")
  startedAt             DateTime                @default(now())
  endedAt               DateTime?
  duration              Int?
  latencyAvg            Float?
  conversationLog       Json
  userSentiment         String?
  gcpSessionId          String?                 @unique
  vertexAiModel         String                  @default("gemini-1.5-pro")
  cloudRunEndpoint      String?
  thoughtSignatures     Json?
  avatars               avatars?                @relation(fields: [avatar_id], references: [id])
  users                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation_messages conversation_messages[]
  observations          observations[]

  @@index([gcpSessionId])
  @@index([userId, startedAt])
}

model avatars {
  id               String            @id
  name             String
  description      String?
  system_prompt    String
  voice_id         String
  avatar_image_url String?
  category         String
  created_at       DateTime          @default(now())
  updated_at       DateTime
  avatar_sessions  avatar_sessions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model companion_certificates {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id           String                @db.Uuid
  name                 String
  role                 String
  tier                 String                @default("NOVICE")
  persona              Json?                 @default("{}")
  voice_id             String?               @default("eleven_labs_default")
  avatar_id            String?               @default("heygen_default")
  master_system_prompt String                @default("")
  district_id          String?               @default("MOBILE_COUNTY_AL")
  metadata             Json?                 @default("{}")
  created_at           DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  knowledge_documents  knowledge_documents[]

  @@index([created_at(sort: Desc)], map: "idx_companion_certificates_created")
  @@index([creator_id], map: "idx_companion_certificates_creator")
  @@index([district_id], map: "idx_companion_certificates_district")
}

model conversation_messages {
  id              String           @id
  session_id      String?
  user_id         String
  role            String
  content         String
  feedback        Int?
  metadata        Json?
  created_at      DateTime         @default(now())
  avatar_sessions avatar_sessions? @relation(fields: [session_id], references: [id])
  users           User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@index([user_id])
}

model district_nodes {
  id                 String    @id
  district_id        String
  name               String
  status             String    @default("optimal")
  health             Float     @default(95.0)
  active_swarms      Int       @default(0)
  last_pulse         DateTime  @default(now())
  created_at         DateTime  @default(now())
  updated_at         DateTime
  vaultCompliance    Float     @default(100.0)
  vaultDocumentCount Int       @default(0)
  districts          districts @relation(fields: [district_id], references: [id], onDelete: Cascade)

  @@unique([district_id, name])
}

model districts {
  id             String           @id
  name           String           @unique
  health         Float            @default(98.0)
  last_pulse     DateTime         @default(now())
  created_at     DateTime         @default(now())
  updated_at     DateTime
  district_nodes district_nodes[]
}

model documents {
  id               String           @id
  evidenceFolderId String
  fileName         String
  fileType         String
  fileSize         Int
  gcpBucketPath    String
  gcpSignedUrl     String?
  urlExpiresAt     DateTime?
  encrypted        Boolean          @default(true)
  accessLevel      String           @default("private")
  uploadedAt       DateTime         @default(now())
  evidence_folders evidence_folders @relation(fields: [evidenceFolderId], references: [id], onDelete: Cascade)

  @@index([evidenceFolderId])
  @@index([fileType])
}

model evidence_folders {
  id              String         @id
  userId          String
  studentId       String
  gradeLevel      String?
  specialEdStatus String?
  title           String
  category        String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  aiSummary       String?
  riskLevel       String?
  complianceScore Float?
  documents       documents[]
  users           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  observations    observations[]

  @@index([category, riskLevel])
  @@index([userId, studentId])
}

model generated_content_hub {
  id             String        @id
  user_id        String
  type           String
  title          String
  description    String?
  prompt         String
  content        Json?
  legacy_content String?
  subject        String?
  grade_level    String?
  media_urls     String[]
  ai_model       String?
  tokens_used    Int?
  is_public      Boolean       @default(false)
  tags           String[]
  created_at     DateTime      @default(now())
  updated_at     DateTime
  users          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  saved_items    saved_items[]

  @@index([type])
  @@index([user_id])
}

model generations {
  id                String   @id
  userId            String
  generatorId       String
  prompt            String
  content           String
  professorVideoUrl String?
  avatarEngine      String?
  createdAt         DateTime @default(now())
  users             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([generatorId])
  @@index([userId, createdAt])
}

model graph_edges {
  id                                            String      @id
  type                                          String
  properties                                    Json?
  sourceId                                      String
  targetId                                      String
  weight                                        Float       @default(1.0)
  created_at                                    DateTime    @default(now())
  graph_nodes_graph_edges_sourceIdTograph_nodes graph_nodes @relation("graph_edges_sourceIdTograph_nodes", fields: [sourceId], references: [id], onDelete: Cascade)
  graph_nodes_graph_edges_targetIdTograph_nodes graph_nodes @relation("graph_edges_targetIdTograph_nodes", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([targetId])
  @@index([type])
}

model graph_nodes {
  id                                            String        @id
  label                                         String
  name                                          String
  properties                                    Json?
  created_at                                    DateTime      @default(now())
  graph_edges_graph_edges_sourceIdTograph_nodes graph_edges[] @relation("graph_edges_sourceIdTograph_nodes")
  graph_edges_graph_edges_targetIdTograph_nodes graph_edges[] @relation("graph_edges_targetIdTograph_nodes")

  @@index([label])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model knowledge_documents {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companion_id           String?                 @db.Uuid
  owner_id               String?
  name                   String
  content                String
  embedding              Unsupported("vector")?
  metadata               Json?                   @default("{}")
  created_at             DateTime?               @default(now()) @db.Timestamptz(6)
  companion_certificates companion_certificates? @relation(fields: [companion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                  User?                   @relation(fields: [owner_id], references: [id], onUpdate: NoAction)

  @@index([embedding], map: "idx_knowledge_embeddings")
  @@index([embedding])
  @@index([embedding], map: "knowledge_documents_embedding_idx1")
}

model legacy_ledger {
  id            String   @id
  user_id       String
  title         String
  directive     String
  logic         String
  swarm_context Json
  outcome       String?
  learnings     String?
  is_immutable  Boolean  @default(true)
  tags          String[] @default([])
  created_at    DateTime @default(now())
  updated_at    DateTime
  users         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model observations {
  id               String            @id
  userId           String
  evidenceFolderId String?
  avatarSessionId  String?
  observationType  String
  observationDate  DateTime          @default(now())
  duration         Int?
  description      String
  context          String?
  interventions    String?
  aiAnalysis       String?
  suggestedActions Json?
  legalCompliance  Boolean           @default(false)
  hasAudio         Boolean           @default(false)
  hasVideo         Boolean           @default(false)
  hasImages        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  avatar_sessions  avatar_sessions?  @relation(fields: [avatarSessionId], references: [id])
  evidence_folders evidence_folders? @relation(fields: [evidenceFolderId], references: [id])
  users            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([evidenceFolderId])
  @@index([observationType])
  @@index([userId, observationDate])
}

model organizations {
  id                 String   @id
  name               String
  tier               String   @default("SCHOOL_SITE")
  trial_started_at   DateTime @default(now())
  trial_starts_at    DateTime @default(now())
  trial_ends_at      DateTime
  is_trial_converted Boolean  @default(false)
  usage_tokens       Int      @default(0)
  address            String?
  contact_email      String?
  created_at         DateTime @default(now())
  updated_at         DateTime
  users              User[]
}

model saved_items {
  id                    String                @id
  user_id               String
  content_id            String
  folder_name           String?
  created_at            DateTime              @default(now())
  generated_content_hub generated_content_hub @relation(fields: [content_id], references: [id], onDelete: Cascade)
  users                 User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, content_id])
  @@index([user_id])
}

model schools {
  id                             String               @id
  name                           String
  district_name                  String?
  state                          String?
  zip_code                       String?
  admin_id                       String?
  stripe_customer_id             String?              @unique
  subscription_tier              String               @default("free")
  max_users                      Int                  @default(5)
  created_at                     DateTime             @default(now())
  updated_at                     DateTime
  analytics_insights             analytics_insights[]
  users_schools_admin_idTousers  User?                @relation("schools_admin_idTousers", fields: [admin_id], references: [id])
  subscriptions                  subscriptions[]
  users_users_school_idToschools User[]               @relation("users_school_idToschools")

  @@index([admin_id])
}

model semantic_caches {
  id          String   @id
  query       String
  response    String
  hit_count   Int      @default(0)
  last_hit_at DateTime @default(now())
  created_at  DateTime @default(now())
}

model strategic_vault {
  id         String   @id
  user_id    String
  file_name  String
  content    String?
  metadata   Json     @default("{}")
  tags       String[] @default([])
  created_at DateTime @default(now())
  updated_at DateTime
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model subscriptions {
  id                     String    @id
  user_id                String?
  school_id              String?
  stripe_subscription_id String    @unique
  stripe_price_id        String
  status                 String
  current_period_start   DateTime
  current_period_end     DateTime
  cancel_at_period_end   Boolean   @default(false)
  created_at             DateTime  @default(now())
  updated_at             DateTime
  signup_fee_paid        Boolean   @default(false)
  trial_ends_at          DateTime?
  trial_started_at       DateTime  @default(now())
  schools                schools?  @relation(fields: [school_id], references: [id])
  users                  User?     @relation(fields: [user_id], references: [id])

  @@index([school_id])
  @@index([user_id])
}

model system_feedback {
  id           String   @id
  user_id      String?
  type         String
  rating       Int?
  message      String?
  context_data Json?
  created_at   DateTime @default(now())
  users        User?    @relation(fields: [user_id], references: [id])

  @@index([created_at])
}

model tiers {
  id        String @id
  name      String @unique
  stripeUrl String
  users     User[]
}

model token_ledger {
  id              String        @id
  user_id         String?
  wallet_id       String
  amount          Int
  type            String        @default("DEBIT")
  description     String?
  generation_type String?
  timestamp       DateTime      @default(now())
  token_wallets   token_wallets @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  @@index([wallet_id, timestamp])
}

model token_wallets {
  id                     String         @id
  user_id                String         @unique
  balance                Int            @default(0)
  monthly_limit          Int            @default(1000)
  daily_limit            Int            @default(100)
  tokens_used_this_month Int            @default(0)
  tokens_used_today      Int            @default(0)
  last_reset_date        DateTime       @default(now())
  requires_upsell        Boolean        @default(false)
  token_ledger           token_ledger[]
  users                  User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model usage_tracking {
  id                  String   @id
  user_id             String
  month               DateTime @db.Date
  conversations_count Int      @default(0)
  messages_count      Int      @default(0)
  content_generated   Int      @default(0)
  images_generated    Int      @default(0)
  videos_generated    Int      @default(0)
  voice_minutes       Int      @default(0)
  tokens_used         Int      @default(0)
  users               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, month])
  @@index([user_id])
}

model User {
  id                               String                  @id
  clerk_id                         String?                 @unique
  email                            String                  @unique
  name                             String?
  role                             UserRole                @default(TEACHER)
  district                         String?
  school                           String?
  school_site                      String?
  position                         String?
  bio                              String?
  organization_id                  String?
  school_id                        String?
  stripe_customer_id               String?                 @unique
  stripe_subscription_id           String?                 @unique
  subscription_tier                String                  @default("free")
  subscription_status              String                  @default("inactive")
  usage_tokens                     Int                     @default(10)
  xp_points                        Int                     @default(0)
  trial_started_at                 DateTime                @default(now())
  trial_ends_at                    DateTime?
  is_trial_converted               Boolean                 @default(false)
  is_active                        Boolean                 @default(true)
  tier_id                          String?
  avatar_url                       String?
  created_at                       DateTime                @default(now())
  updated_at                       DateTime
  last_login                       DateTime?
  password                         String?
  emailVerified                    Boolean                 @default(false)
  image                            String?
  lastUplinkAt                     DateTime?
  accounts                         account[]
  sessions                         session[]
  analytics_insights               analytics_insights[]
  avatar_sessions                  avatar_sessions[]
  conversation_messages            conversation_messages[]
  evidence_folders                 evidence_folders[]
  generated_content_hub            generated_content_hub[]
  generations                      generations[]
  legacy_ledger                    legacy_ledger[]
  observations                     observations[]
  saved_items                      saved_items[]
  schools_schools_admin_idTousers  schools[]               @relation("schools_admin_idTousers")
  strategic_vault                  strategic_vault[]
  subscriptions                    subscriptions[]
  system_feedback                  system_feedback[]
  token_wallets                    token_wallets?
  usage_tracking                   usage_tracking[]
  organizations                    organizations?          @relation(fields: [organization_id], references: [id])
  schools_users_school_idToschools schools?                @relation("users_school_idToschools", fields: [school_id], references: [id])
  tiers                            tiers?                  @relation(fields: [tier_id], references: [id])
  vault_documents                  vault_documents[]
  knowledge_documents              knowledge_documents[]

  @@index([clerk_id])
  @@index([district, school])
  @@index([email])
  @@index([organization_id])
  @@index([school_id])
  @@map("users")
}

model session {
  id        String   @id
  userId    String
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model vault_audits {
  id              String          @id
  documentId      String
  userId          String
  action          String
  ipAddress       String?
  userAgent       String?
  timestamp       DateTime        @default(now())
  vault_documents vault_documents @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model vault_documents {
  id                String         @id
  userId            String
  fileName          String
  fileSize          Int
  fileType          String
  storagePath       String
  isEncrypted       Boolean        @default(true)
  securityLevel     String         @default("confidential")
  tags              String[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime
  encrypted_content String?
  encryption_iv     String?
  vault_audits      vault_audits[]
  users             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vault_ocr         vault_ocr?

  @@index([userId])
}

model vault_ocr {
  id              String          @id
  documentId      String          @unique
  extractedText   String
  confidence      Float?
  processedAt     DateTime        @default(now())
  vault_documents vault_documents @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

enum aal_level {
  aal1
  aal2
  aal3
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INACTIVE
}

enum UserRole {
  TEACHER
  ADMIN
  COUNSELOR
  STUDENT
  SUPERINTENDENT
  EXECUTIVE
  PRINCIPAL
}
