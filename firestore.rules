rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /parental_consents/{consentId} {
      allow create: if true; 
      allow read: if request.auth != null && request.auth.token.admin == true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
